# WordPress headless backend (required for data fetching)
# No trailing slash. Examples:
#   Local:   http://headless-wpnext-blog.local  or  http://localhost:10010
#   Live:    https://fs26-back.felixseeger.de
WORDPRESS_API_URL=

# Same URL as WORDPRESS_API_URL; required for contact form (client posts to CF7 REST API).
# Use https in production so CORS and redirects work.
NEXT_PUBLIC_WORDPRESS_API_URL=

# Public site URL for canonicals, sitemap, and OG (no trailing slash). Examples:
#   Local:   http://localhost:3000
#   Live:    https://felixseeger.de
NEXT_PUBLIC_SITE_URL=

# Optional: use unoptimized images (e.g. for static export on hosts without Next image optimization)
# NEXT_IMAGE_UNOPTIMIZED=true

# Contact Form 7 form ID (required for contact form submission)
# Find in WP admin: edit form → URL has post=123 → use 123
# CONTACT_FORM_7_ID=123

# MailerLite newsletter integration (optional)
# Get a subscriber-write-only API key from MailerLite → Integrations → API
NEXT_PUBLIC_MAILERLITE_API_KEY=
# Group IDs from MailerLite → Subscribers → Groups → click group → ID in URL
NEXT_PUBLIC_ML_GROUP_BLOG=
NEXT_PUBLIC_ML_GROUP_COURSE=

# Gmail SMTP — transactional email for enrollment confirmations (free)
# Use any Gmail account; generate an App Password at:
#   https://myaccount.google.com/apppasswords  (requires 2-Step Verification)
EMAIL_USER=yourname@gmail.com
EMAIL_PASS=xxxx xxxx xxxx xxxx

# PayPal payment integration (required for course checkout)
# Get credentials from: https://developer.paypal.com/dashboard/applications
# Server-only keys — no NEXT_PUBLIC_ prefix
# PAYPAL_ENV defaults to "sandbox"; set to "live" for production
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_ENV=sandbox

# Shared secret for WordPress order endpoint (POST /wp-json/fs/v1/orders)
WP_ORDER_SECRET=

# WooCommerce REST API (required for /shop page)
# Generate keys in WP Admin → WooCommerce → Settings → Advanced → REST API
WC_CONSUMER_KEY=ck_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WC_CONSUMER_SECRET=cs_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Plausible Analytics — privacy-first, cookieless (no consent banner needed)
# Sign up at https://plausible.io and create a site for your domain.
# Set to your bare domain, e.g. "felixseeger.de" (no https:// or trailing slash).
# Leave empty to disable analytics in development.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# ---
# Setup:
# 1. Copy this file to .env.local (dev) and set WORDPRESS_API_URL (and NEXT_PUBLIC_SITE_URL for canonicals/sitemap).
# 2. For production build: run  node scripts/deploy:prepare
#    (reads backend URL from conf/start.md and writes .env.production.local)
